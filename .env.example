PORT=10000
NODE_ENV=development

# Cafe24 OAuth
MALL_ID=cellfusionc2023
CLIENT_ID=your_client_id_here
CLIENT_SECRET=your_client_secret_here
REDIRECT_URI=https://your-domain.com/cafe24/callback
SCOPE=mall.read_product mall.read_category

# Data / AI
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority
OPENAI_API_KEY=sk-...
RERANK_MODEL=gpt-4o-mini

# Public app URL (used by MCP widget resource rewriting)
PUBLIC_BASE_URL=https://cafe24-api.onrender.com

# Logging controls
LOG_LEVEL=debug
LOG_MCP_VERBOSE=false
LOG_CACHE_FILTER=false
LOG_TOKEN_EVENTS=false
