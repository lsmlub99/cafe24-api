PORT=10000
NODE_ENV=development

# Cafe24 OAuth
MALL_ID=cellfusionc2023
CLIENT_ID=your_client_id_here
CLIENT_SECRET=your_client_secret_here
REDIRECT_URI=https://your-domain.com/cafe24/callback
SCOPE=mall.read_product mall.read_category

# Data / AI
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority
OPENAI_API_KEY=sk-...
RERANK_MODEL=gpt-4o-mini

# Public app URL (used by MCP widget resource rewriting)
PUBLIC_BASE_URL=https://cafe24-api.onrender.com

# Hybrid enrich controls (request-time detail fetch)
# - BASE: default mode (usually 0 for fastest responses)
# - INGREDIENT: enabled when query includes ingredient/sensitivity signals
ENRICH_MAX_FETCH_BASE=0
ENRICH_MAX_FETCH_INGREDIENT=4

# Seed category IDs when name-based auto-detection misses them (JSON).
# Each seed ID also gets its child categories traversed automatically.
# Example: {"선케어":[29]} adds category 29 + all its subcategories to sunscreen lookup.
CATEGORY_NO_OVERRIDES=

# Logging controls
LOG_LEVEL=debug
LOG_MCP_VERBOSE=false
LOG_CACHE_FILTER=false
LOG_TOKEN_EVENTS=false
