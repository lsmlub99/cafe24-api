# [필수] 서버 구동 포트
PORT=3000

# [필수] 카페24 상점 아이디
MALL_ID=cellfusionc2023

# [필수] 카페24 앱 클라이언트 아이디 (App Key)
CLIENT_ID=your_client_id_here

# [필수] 카페24 앱 클라이언트 시크릿 (Secret Key)
CLIENT_SECRET=your_client_secret_here

# [필수] 운영 환경 리다이렉트 주소 
REDIRECT_URI=https://api.cellfusionc.co.kr/cafe24/callback

# [필수] 사용할 API 스코프
# 다중 권한 필요 시 공백으로 구분합니다. 예: mall.read_product mall.read_order
SCOPE=mall.read_product
